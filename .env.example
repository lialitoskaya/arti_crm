APP_ENV=local
DATABASE_PATH=./crm.sqlite3

# CRM employee login/password access
# On first launch, if the users table is empty, CRM creates this admin account.
CRM_ADMIN_USERNAME=admin
CRM_ADMIN_PASSWORD=change_me_please
CRM_ADMIN_DISPLAY_NAME=Администратор
CRM_AUTH_DISABLED=false
CRM_COOKIE_SECURE=false

# Ozon Seller API
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_BACKGROUND_SYNC=true
OZON_SYNC_MAX_CHATS=500
OZON_SYNC_PAGES_PER_VARIANT=5
OZON_SYNC_VARIANT_MODE=full
OZON_BACKGROUND_SYNC_MAX_CHATS=80
OZON_BACKGROUND_SYNC_PAGES_PER_VARIANT=3
OZON_BACKGROUND_SYNC_VARIANT_MODE=full
OZON_BACKGROUND_SYNC_MIN_INTERVAL_SECONDS=60
OZON_SYNC_INCLUDE_CLOSED=false
OZON_EXCLUDE_SUPPORT_CHATS=0

# Ozon system dialog filtering when chat_type=UNSPECIFIED
OZON_EXCLUDE_SYSTEM_HISTORY_CHATS=0
OZON_SYSTEM_DIALOG_MARKERS=notificationuser,notification_user,systemuser,system_user

# Ozon Reviews API
# If chats start missing again, temporarily set OZON_REVIEWS_BACKGROUND_SYNC=false.
OZON_REVIEWS_BACKGROUND_SYNC=false
OZON_REVIEWS_SYNC_LIMIT=50
OZON_REVIEWS_SYNC_PAGES=2
OZON_REVIEWS_BACKGROUND_LIMIT=20
OZON_REVIEWS_BACKGROUND_PAGES=1
OZON_REVIEWS_STATUSES=UNPROCESSED,PROCESSED
OZON_REVIEWS_FETCH_INFO=false
OZON_REVIEWS_FETCH_COMMENTS=false
OZON_REVIEWS_BACKGROUND_MIN_INTERVAL_SECONDS=300

# Ozon Questions / Answers API
OZON_QUESTIONS_BACKGROUND_SYNC=true
OZON_QUESTIONS_SYNC_LIMIT=50
OZON_QUESTIONS_SYNC_PAGES=3
OZON_QUESTIONS_BACKGROUND_LIMIT=30
OZON_QUESTIONS_BACKGROUND_PAGES=1
OZON_QUESTIONS_STATUSES=UNPROCESSED,PROCESSED
OZON_QUESTIONS_FETCH_INFO=true
OZON_QUESTIONS_SORT_DIR=DESC
OZON_QUESTIONS_MIN_INTERVAL_SECONDS=300

# Yandex Market Partner API
YANDEX_MARKET_TOKEN=
YANDEX_MARKET_BUSINESS_ID=
YANDEX_MARKET_CAMPAIGN_ID=
YANDEX_BACKGROUND_SYNC=true
YANDEX_SYNC_MAX_CHATS=50
YANDEX_SYNC_MAX_PAGES=3
YANDEX_BACKGROUND_SYNC_MAX_CHATS=30
YANDEX_BACKGROUND_SYNC_MAX_PAGES=1
YANDEX_BACKGROUND_SYNC_MIN_INTERVAL_SECONDS=30

# Wildberries Buyers Chat API
# Main variable: WB_BUYERS_CHAT_TOKEN. WB_API_TOKEN is also accepted as fallback.
WB_BUYERS_CHAT_TOKEN=
WB_API_TOKEN=
WB_BACKGROUND_SYNC=true
WB_SYNC_MAX_EVENTS=100
WB_SYNC_EVENT_PAGES=1
WB_BACKGROUND_SYNC_MAX_EVENTS=50
WB_BACKGROUND_SYNC_EVENT_PAGES=1
# WB can return an hourly limit for some tokens; keep these values high to stop 429 storms.
WB_BACKGROUND_SYNC_MIN_INTERVAL_SECONDS=3700
WB_RATE_LIMIT_COOLDOWN_SECONDS=3700
WB_RATE_LIMIT_STATE_FILE=.wb_rate_limit_until

# Common background sync for all configured marketplaces
MARKETPLACE_BACKGROUND_SYNC=true
MARKETPLACE_BACKGROUND_SYNC_INTERVAL=10
MARKETPLACE_MESSAGE_FETCH_CONCURRENCY=8

# OpenAI API for AI reply drafts
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=700
AI_COMPANY_NAME=Arti
AI_REPLY_STYLE=Вежливо, кратко, по делу, без обещаний скидок/компенсаций и без перевода клиента в сторонние мессенджеры.

# WB messages: parser now uses events + lastMessage fallback. Keep event pages low to avoid 429.

# WB chat events history window. Increase manually only if needed.
WB_EVENTS_LOOKBACK_DAYS=30
WB_EVENTS_START_TIMESTAMP_MS=0

# WB: do not fetch events in normal chat list sync; use /api/debug/wb/import-events manually after cooldown.
WB_FETCH_EVENTS_WITH_CHAT_LIST=false

# WB: saved cursor for one-page-per-hour events history import.
WB_EVENTS_CURSOR_STATE_FILE=.wb_events_cursor.json

# WB: automatic one-page-per-hour events/history import planner.
WB_EVENTS_AUTO_IMPORT_ENABLED=true
WB_EVENTS_AUTO_IMPORT_KEEP_ALIVE=true
WB_EVENTS_AUTO_IMPORT_PLAN_FILE=.wb_events_auto_import.json
WB_EVENTS_AUTO_IMPORT_INTERVAL_SECONDS=3700

# Ozon chats/history sync. Normal sync is light; use /api/debug/ozon/backfill-chats for deep import.
OZON_HISTORY_PAGES=1

# Ozon: safe history backfill. Keep all chats by default; do not delete uncertain service-looking chats.
OZON_DELETE_SUPPORT_CHATS=0

# Ozon: fast inbox sync for new/recent chats. Deep backfill remains separate.
OZON_FAST_INBOX_SYNC_ENABLED=true
OZON_FAST_SYNC_MAX_CHATS=300
OZON_FAST_SYNC_PAGES_PER_VARIANT=3
OZON_FAST_SYNC_VARIANT_MODE=fast
OZON_FAST_HISTORY_PAGES=1
OZON_FAST_MESSAGE_FETCH_CONCURRENCY=10
OZON_DELETE_SYSTEM_HISTORY_CHATS=0

OZON_MARK_SYSTEM_HISTORY_CHATS=0

# Analytics timezone: 180 = UTC+3.
CRM_ANALYTICS_TZ_OFFSET_MINUTES=180

# CRM workflow: first employee who successfully replies to an unassigned chat becomes responsible.
CRM_AUTO_ASSIGN_FIRST_RESPONSE=true

# In-app notifications
CRM_NOTIFICATION_RECENT_MESSAGE_HOURS=24

# Ozon technical ChatBot filtering
OZON_EXCLUDE_CHATBOT_CHATS=1
OZON_EXCLUDE_CHATBOT_MESSAGES=1
OZON_CHATBOT_MARKERS=chatbot
